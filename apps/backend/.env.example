DOCUMENT_REGISTRY_ADDRESS="0x..."  # Contrato DocumentRegistry desplegado

# Encriptación metadata (AES-256)
# 64 caracteres hex = 32 bytes para clave directa
METADATA_ENCRYPTION_KEY="your-32-byte-hex-key-here-64-chars"

# Storage
STORAGE_PATH="./storage"
