// HealthProof - Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Issuer {
  id            String    @id @default(uuid())
  name          String
  walletAddress String    @unique
  licenseHash   String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  documents     Document[]
}

model Document {
  id                    String       @id @default(uuid())
  documentHash          String       @unique
  metadataHash          String
  encryptedMetadataPath String?      // Path/key donde se almacena metadata encriptada
  txHash                String?      // Hash de transacción Avalanche
  issuerId              String
  issuer                Issuer       @relation(fields: [issuerId], references: [id])
  revoked               Boolean      @default(false)
  createdAt             DateTime     @default(now())
  accessGrants          AccessGrant[]

  @@index([issuerId])
  @@index([txHash])
}

model AccessGrant {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  verifier   String
  expiresAt DateTime

  @@index([documentId])
  @@index([verifier, expiresAt])
}
